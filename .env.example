# ══════════════════════════════════════════════════════════════
#  MPAS Backend — copy this file to  .env  and fill in values
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/mpas

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# ── Server ────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════
#  EMAIL  — fill ONE section below
# ══════════════════════════════════════════════════════════════

# ── OPTION A: Gmail (recommended, free) ───────────────────────
#
#  Step-by-step:
#  1. Go to  https://myaccount.google.com/security
#  2. Turn ON  2-Step Verification  (required)
#  3. Go to   https://myaccount.google.com/apppasswords
#  4. App = "Mail", Device = "Other" → type "MPAS" → Generate
#  5. Copy the 16-character password shown (spaces are fine)
#  6. Paste below and uncomment:
#
EMAIL_USER=your@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop
EMAIL_FROM="MPAS Alert" <your@gmail.com>

# ── OPTION B: Other SMTP (Outlook, Yahoo, SendGrid…) ──────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@outlook.com
# SMTP_PASS=yourpassword

# ══════════════════════════════════════════════════════════════
#  After filling in, restart the server.
#  You should see:  ✅ Email service: Gmail (your@gmail.com)
#
#  To test: GET http://localhost:5000/api/auth/test-email?to=your@email.com
#  (while logged in as admin)
# ══════════════════════════════════════════════════════════════
